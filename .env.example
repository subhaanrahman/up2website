# Supabase (required for app)
# VITE_SUPABASE_URL must point to your Supabase project (e.g. https://xxx.supabase.co).
# Use localhost (http://127.0.0.1:54321) only when running supabase start locally.
# Publishable key (sb_publishable_...) is fine. If Edge Functions return 401 before your code runs,
# ensure supabase/config.toml sets verify_jwt = false for those functions and redeploy (see events-create, message-send).
#
# Optional: copy this file to .env then use .env.local for machine-specific overrides (gitignored).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Stripe (required for checkout; get from dashboard.stripe.com → Developers → API keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Optional: Sentry browser SDK — errors from ErrorBoundary + captureApiError (see docs/TESTING_GUIDE.md)
# VITE_SENTRY_DSN=

# Optional: default city for logged-out users (nearby carousel + Events "For You"), e.g. Sydney
# VITE_DEFAULT_GUEST_CITY=

# Optional: Spotify (for Connect Music)
# VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
