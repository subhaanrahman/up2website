# Supabase (required for app)
# VITE_SUPABASE_URL must point to your Supabase project (e.g. https://xxx.supabase.co).
# Use localhost (http://127.0.0.1:54321) only when running supabase start locally.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Stripe (required for checkout; get from dashboard.stripe.com → Developers → API keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Optional: Sentry browser SDK (errors from ErrorBoundary + captureApiError)
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Optional: Spotify (for Connect Music)
# VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
